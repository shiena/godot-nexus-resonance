[configuration]

entry_symbol = "nexus_resonance_library_init"
compatibility_minimum = "4.1"
doc_path = "doc_classes"

[libraries]

windows.debug.x86_64 = "res://addons/nexus_resonance/bin/nexus_resonance.dll"
windows.release.x86_64 = "res://addons/nexus_resonance/bin/nexus_resonance.dll"

linux.debug.x86_64 = "res://addons/nexus_resonance/bin/libnexus_resonance.so"
linux.release.x86_64 = "res://addons/nexus_resonance/bin/libnexus_resonance.so"

macos.debug.arm64 = "res://addons/nexus_resonance/bin/libnexus_resonance.dylib"
macos.release.arm64 = "res://addons/nexus_resonance/bin/libnexus_resonance.dylib"
macos.debug.x86_64 = "res://addons/nexus_resonance/bin/libnexus_resonance.dylib"
macos.release.x86_64 = "res://addons/nexus_resonance/bin/libnexus_resonance.dylib"

android.debug.arm64 = "res://addons/nexus_resonance/bin/android/arm64-v8a/libnexus_resonance.so"
android.release.arm64 = "res://addons/nexus_resonance/bin/android/arm64-v8a/libnexus_resonance.so"
android.arm64-v8a = "res://addons/nexus_resonance/bin/android/arm64-v8a/libnexus_resonance.so"
android.debug.arm32 = "res://addons/nexus_resonance/bin/android/armeabi-v7a/libnexus_resonance.so"
android.release.arm32 = "res://addons/nexus_resonance/bin/android/armeabi-v7a/libnexus_resonance.so"
android.armeabi-v7a = "res://addons/nexus_resonance/bin/android/armeabi-v7a/libnexus_resonance.so"
android.debug.x86_64 = "res://addons/nexus_resonance/bin/android/x86_64/libnexus_resonance.so"
android.release.x86_64 = "res://addons/nexus_resonance/bin/android/x86_64/libnexus_resonance.so"
android.x86_64 = "res://addons/nexus_resonance/bin/android/x86_64/libnexus_resonance.so"
android.debug.x86_32 = "res://addons/nexus_resonance/bin/android/x86/libnexus_resonance.so"
android.release.x86_32 = "res://addons/nexus_resonance/bin/android/x86/libnexus_resonance.so"
android.x86 = "res://addons/nexus_resonance/bin/android/x86/libnexus_resonance.so"

[icons]
ResonanceProbeVolume = "res://addons/nexus_resonance/ui/icons/probe_volume_3d_icon.svg"
ResonanceGeometry = "res://addons/nexus_resonance/ui/icons/resonance_geometry_icon.svg"
ResonanceStaticGeometry = "res://addons/nexus_resonance/ui/icons/resonance_static_geometry_icon.svg"
ResonanceDynamicGeometry = "res://addons/nexus_resonance/ui/icons/resonance_dyn_geometry.svg"
ResonancePlayer = "res://addons/nexus_resonance/ui/icons/audio_stream_player_3d_icon.svg"
ResonanceAmbisonicPlayer = "res://addons/nexus_resonance/ui/icons/resonance_ambisonic_player_icon.svg"